# === 只跟踪夕语 ===
# 忽略所有顶层目录，再单独排除夕语
/*
!.gitignore
!vesper_backend/
!vesper_frontend/
!vesper_new_frontend/
!vesper_mobile/

# === 通用排除 ===
# Python
__pycache__/
*.py[cod]
*.pyo
*.egg-info/
venv/
.venv/
*.egg

# Node
node_modules/
npm-debug.log*

# Build / Dist
dist/
build/
*.spec

# Database / Data
data/
*.db
*.sqlite
*.sqlite3
chroma_db/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code
.claude/projects/*/sessions/

# MCP cache
.webcache/

# Temp
*.tmp
*.log
