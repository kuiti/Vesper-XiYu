import requests
from core.db import get_config

_sentiment_cache = {}

def analyze_sentiment(text):
    """用 DeepSeek API 快速分类情感：positive/negative/neutral"""
    if not text or len(text.strip()) < 2:
        return "neutral"
    key = text.strip()[:100]
    if key in _sentiment_cache:
        return _sentiment_cache[key]

    api_key = get_config("api_key", "")
    if not api_key:
        return "neutral"

    prompt = f"只输出一个词（positive/negative/neutral）来分类以下消息的情感：\n{text[:200]}"
    base_url = get_config("api_base_url", "https://api.deepseek.com/v1").rstrip("/")
    model = get_config("api_model", "deepseek-chat")
    headers = {"Authorization": f"Bearer {api_key}", "Content-Type": "application/json"}
    payload = {
        "model": model,
        "messages": [{"role": "user", "content": prompt}],
        "temperature": 0,
        "max_tokens": 10,
        "stream": False
    }
    try:
        resp = requests.post(f"{base_url}/chat/completions",
                             headers=headers, json=payload, timeout=10)
        resp.raise_for_status()
        result = resp.json()["choices"][0]["message"]["content"].strip().lower()
        if "positive" in result:
            result = "positive"
        elif "negative" in result:
            result = "negative"
        else:
            result = "neutral"
    except Exception:
        result = "neutral"

    _sentiment_cache[key] = result
    if len(_sentiment_cache) > 200:
        _sentiment_cache.pop(next(iter(_sentiment_cache)))
    return result
